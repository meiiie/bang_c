  "workflows": {
    "contest-auto": {
      "description": "Final contest path: model auto strategy, no dev-only assumptions.",
      "strategy": "auto",
      "verify": false,
      "dry_run": false,
      "phase": "runtime"
    },
    "contest-strict": {
      "description": "Accuracy-first contest path: verify every answer and keep checkpoints for long runs.",
      "strategy": "auto",
      "verify": true,
      "dry_run": false,
      "phase": "runtime"
    },
    "quick-dry-run": {
      "description": "Contract smoke without API calls.",
      "strategy": "auto",
      "verify": false,
      "dry_run": true,
      "phase": "development"
    },
    "verify-all": {
      "description": "Force a second answer-only pass for every item.",
      "strategy": "verify",
      "verify": true,
      "dry_run": false,
      "phase": "development"
    },
    "tournament": {
      "description": "Use multiple prompt variants and vote synthesis.",
      "strategy": "tournament",
      "verify": true,
      "dry_run": false,
      "phase": "development"
    }
  },
