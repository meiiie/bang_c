  "runtime": {
    "active_profile": "gemma26b-q4-local",
    "provider": "local_llamacpp",
    "default_model": "google/gemma-4-26B-A4B-it-qat-q4_0-gguf:Q4_0",
    "local_model_repo": "google/gemma-4-26B-A4B-it-qat-q4_0-gguf",
    "local_model_file": "gemma-4-26B_q4_0-it.gguf",
    "local_model_path": "/models/gemma-4-26B_q4_0-it.gguf",
    "local_n_ctx": 8192,
    "local_n_gpu_layers": -1,
    "local_n_threads": 0,
    "local_chat_format": "",
    "local_flash_attn": false,
    "local_n_batch": 0,
    "local_server_url": "http://127.0.0.1:8080/v1",
    "api_model": "google/gemma-4-31b-it",
    "base_url": "https://integrate.api.nvidia.com/v1",
    "allowed_model_families": ["gemma-4", "qwen3.5"],
    "allowed_embedding_families": ["bge-m3", "qwen-rerank"],
    "default_strategy": "auto",
    "self_consistency_samples": 1,
    "reasoning_max_tokens": 2048,
    "reasoning_temperature": 0.8,
    "reasoning_top_p": 0.95,
    "reasoning_top_k": 64,
    "reasoning_few_shot_path": "",
    "tir_samples": 1,
    "tir_exec_timeout_seconds": 5.0,
    "tir_code_max_tokens": 1024,
    "rag_corpus_path": "",
    "rag_top_k": 4,
    "tiered_tier1_samples": 2,
    "tiered_total_samples": 5,
    "self_consistency_challenge_threshold": 0.75,
    "challenger_samples": 3,
    "challenger_provider": "",
    "challenger_model_path": "",
    "challenger_model_id": "",
    "max_retries": 6,
    "retry_base_delay_seconds": 1.5,
    "retry_max_delay_seconds": 30,
    "problem_max_retries": 2,
    "problem_retry_base_delay_seconds": 5,
    "problem_retry_max_delay_seconds": 60,
    "timeout_seconds": 90,
    "repair_invalid_output": true,
    "provider_registry": {
      "local_llamacpp": {
        "kind": "local_gguf",
        "description": "Self-contained local llama.cpp runtime for BTC scoring."
      },
      "nvidia": {
        "kind": "openai_compatible_api",
        "description": "Optional NVIDIA NIM API runtime for development and eval."
      },
      "local_server": {
        "kind": "openai_compatible_localhost",
        "description": "In-container llama.cpp llama-server on localhost: same offline guarantee, continuous batching enables --workers concurrency."
      }
    },
    "profiles": {
      "gemma26b-q4-local": {
        "provider": "local_llamacpp",
        "default_model": "google/gemma-4-26B-A4B-it-qat-q4_0-gguf:Q4_0",
        "local_model_repo": "google/gemma-4-26B-A4B-it-qat-q4_0-gguf",
        "local_model_file": "gemma-4-26B_q4_0-it.gguf",
        "local_model_path": "/models/gemma-4-26B_q4_0-it.gguf",
        "local_n_ctx": 8192,
        "local_n_gpu_layers": -1,
        "local_n_threads": 0,
        "local_chat_format": ""
      },
      "nvidia-gemma31b-api": {
        "provider": "nvidia",
        "default_model": "google/gemma-4-31b-it",
        "api_model": "google/gemma-4-31b-it"
      }
    }
  },
  "workflows": {
    "contest-auto": {
      "description": "Final contest path: model auto strategy, no dev-only assumptions.",
      "strategy": "auto",
      "verify": false,
      "dry_run": false,
      "phase": "runtime"
    },
    "contest-strict": {
      "description": "Accuracy-first contest path: verify every answer and keep checkpoints for long runs.",
      "strategy": "auto",
      "verify": true,
      "dry_run": false,
      "phase": "runtime"
    },
    "quick-dry-run": {
      "description": "Contract smoke without API calls.",
      "strategy": "auto",
      "verify": false,
      "dry_run": true,
      "phase": "development"
    },
    "verify-all": {
      "description": "Force a second answer-only pass for every item.",
      "strategy": "verify",
      "verify": true,
      "dry_run": false,
      "phase": "development"
    },
    "tournament": {
      "description": "Use multiple prompt variants and vote synthesis.",
      "strategy": "tournament",
      "verify": true,
      "dry_run": false,
      "phase": "development"
    },
    "self-consistency": {
      "description": "CONTEST DEFAULT: chain-of-thought reasoning (k=1) with answer extraction. Language-neutral. Leaderboard 2026-06-10: 87.26 vs 77.11 letter-only baseline.",
      "strategy": "self_consistency",
      "verify": false,
      "dry_run": false,
      "phase": "runtime"
    },
    "tiered-consistency": {
      "description": "CANDIDATE for 93+: tiered diverse self-consistency. Tier 1 = anchor + rotated-choice sample (position-bias debias); unanimous -> stop. Disagreement -> escalate to seeded temp>0 rotated samples and majority-vote. Pending real-model measurement before promotion.",
      "strategy": "tiered",
      "verify": false,
      "dry_run": false,
      "phase": "development"
    },
    "tir": {
      "description": "Tool-integrated reasoning: model writes + EXECUTES Python (offline sandbox) to compute, then maps the result onto an option. For the public test's ~25-30% cross-domain quantitative slice. Pending real-model measurement.",
      "strategy": "tir",
      "verify": false,
      "dry_run": false,
      "phase": "development"
    },
    "reading": {
      "description": "Passage-grounded reading mode: quote the passage span, vet each option against the text, reject true-but-off-topic / wrong-attribution / outside-passage distractors. Forces the mode on every item -- for per-bucket measurement on a reading proxy (ViMMRC). Pending real-model measurement.",
      "strategy": "reading",
      "verify": false,
      "dry_run": false,
      "phase": "development"
    },
    "rag": {
      "description": "Targeted retrieval-grounded mode: BM25 over a packaged offline legal/admin corpus (rag_corpus_path; empty = degrades to self-consistency). Excerpts are fallible references, never ground truth. Forces the mode on every item -- for per-bucket measurement on a civics/legal proxy. Pending real-model measurement.",
      "strategy": "rag",
      "verify": false,
      "dry_run": false,
      "phase": "development"
    },
    "router": {
      "description": "CANDIDATE: question-type router on the real-test composition -- quantitative -> TIR (Python exec), passage -> reading-grounding mode, legal/admin factual -> targeted RAG (only when rag_corpus_path is set; default off), everything else -> diverse self-consistency. The 'good combination' for the mixed humanities+math contest. Pending real-model measurement.",
      "strategy": "router",
      "verify": false,
      "dry_run": false,
      "phase": "development"
    }
  },
